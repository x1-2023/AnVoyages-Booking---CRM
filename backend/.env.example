# Database
# Local dev currently uses SQLite. For Supabase/PostgreSQL, change Prisma datasource provider
# to postgresql before migration and use the pooled/direct URL from Supabase.
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# App
PORT=3000
NODE_ENV=development

# CORS
CORS_ORIGIN="http://localhost:5173"

# Public booking anti-spam
TURNSTILE_ENABLED=false
TURNSTILE_SECRET_KEY=""

# Upload storage
# local keeps files under backend/uploads. r2 sends uploaded images to Cloudflare R2.
UPLOAD_DRIVER="local"
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_BASE_URL="https://media.example.com"

# Email (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="noreply@globewanderer.com"

# Telegram Bot
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_ADMIN_CHAT_ID="your-admin-chat-id"

# Admin Default
ADMIN_EMAIL="admin@globewanderer.com"
ADMIN_PASSWORD="Admin@123456"
ADMIN_NAME="System Admin"
