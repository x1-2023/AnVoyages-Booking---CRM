# Database
# Prisma schema uses PostgreSQL. For Supabase, prefer session pooler for long-running Node apps
# unless your deployment environment supports direct IPv6.
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@[REGION].pooler.supabase.com:5432/postgres"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
ANVOYAGES_SERVICE_TOKEN="shared-secret-token-used-by-vieterp-travelops"

# App
PORT=3000
NODE_ENV=development

# CORS
CORS_ORIGIN="http://localhost:5173"

# Public booking anti-spam
TURNSTILE_ENABLED=false
TURNSTILE_SECRET_KEY=""

# Upload storage
# local keeps files under backend/uploads. r2 sends uploaded images to Cloudflare R2.
# Keep UPLOAD_DRIVER=local until R2_ACCESS_KEY_ID and R2_SECRET_ACCESS_KEY are set.
UPLOAD_DRIVER="local"
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_SESSION_TOKEN=""
R2_BUCKET="anvoyages-media"
R2_PUBLIC_BASE_URL="https://pub-cc52d0d156684b5da8c4bb0f163eb065.r2.dev"

# Email (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="noreply@globewanderer.com"

# Telegram Bot
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_ADMIN_CHAT_ID="your-admin-chat-id"

# Admin Default
ADMIN_EMAIL="admin@globewanderer.com"
ADMIN_PASSWORD="Admin@123456"
ADMIN_NAME="System Admin"
